# ─── Banco de Dados ────────────────────────────────────────────
MARIADB_DATABASE=wordpress
MARIADB_USER=wp_user
MARIADB_PASSWORD=wp_password
MARIADB_ROOT_PASSWORD=root_password

# ─── WordPress ─────────────────────────────────────────────────
WP_PORT=8080
WP_DEBUG=true

# ─── WordPress Admin (usado pelo setup.sh) ─────────────────────
PROJECT_NAME=Meu Projeto WordPress
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=dev@localhost.local

# ─── phpMyAdmin (profile: dev) ─────────────────────────────────
PMA_PORT=8081
