# ─── WordPress ──────────────────────────────────────────────────
WP_PORT=8080
WP_DEBUG=true

# ─── Banco de Dados (MariaDB) ──────────────────────────────────
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=wp_password
MYSQL_ROOT_PASSWORD=root_password

# ─── phpMyAdmin (apenas em dev) ────────────────────────────────
PMA_PORT=8081

# ─── Projeto ───────────────────────────────────────────────────
PROJECT_NAME=Meu Projeto WordPress

# ─── Credenciais padrão de desenvolvimento ─────────────────────
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=dev@localhost.local

# ─── Paths ─────────────────────────────────────────────────────
WORDPRESS_UPLOADS_CONFIG=./config/uploads.ini
NGINX_CONF=./docker/nginx/default.conf
NGINX_SSL_CERTS=./ssl
NGINX_LOGS=./logs/nginx
