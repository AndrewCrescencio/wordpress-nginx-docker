# ─── docker-compose.override.yml.example ────────────────────────
# Copie para docker-compose.override.yml e customize localmente.
# Este arquivo NÃO deve ser versionado (está no .gitignore).
#
# Valores aqui sobrescrevem ou estendem o docker-compose.yml.
# https://docs.docker.com/compose/extends/

services:

  wordpress:
    environment:
      WORDPRESS_CONFIG_EXTRA: |
        define('WP_DEBUG', true);
        define('WP_DEBUG_LOG', true);
        define('WP_DEBUG_DISPLAY', true);
        define('SAVEQUERIES', true);
        # Descomente se estiver usando Redis (docker compose --profile redis up -d)
        # define('WP_REDIS_HOST', 'redis');

  db:
    # Expõe o banco diretamente para conectar com TablePlus, DBeaver, etc.
    ports:
      - "3306:3306"

  phpmyadmin:
    # Força ativação do phpMyAdmin sem precisar do --profile dev
    profiles: []
